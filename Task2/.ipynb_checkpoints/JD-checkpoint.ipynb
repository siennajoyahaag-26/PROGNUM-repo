   "source": [
    "D = float(input(\"Please enter the day (DD): \"))\n",
    "M = float(input(\"The month (MM): \"))\n",
    "Y = float(input(\"The year (YYYY); \"))\n",
    "JD = 367*Y -7*(Y+(M+9)//12)/4 - 3*((Y+(M-9)//7)//100 + 1)//4 + (275*M)//9 + D + 1721029-0.5\n",
    "print(f\"The Julian Date is {JD}\")"
   ]
  }
